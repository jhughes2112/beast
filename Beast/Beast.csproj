<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>Beast</PackageId>
    <PublishSingleFile>true</PublishSingleFile>
    <!-- Halves the self-contained single-file size (~79 MB to ~40 MB) for a small one-time
         decompression cost at startup. Full Native AOT is blocked by reflection-based
         dependencies (Docker.DotNet, Anthropic.SDK, CommandLineParser) — see docs/notes. -->
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <ApplicationIcon Condition="Exists('beast.ico')">beast.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Docker.DotNet" Version="3.125.15" />
    <PackageReference Include="Markdig" Version="1.2.0" />
    <PackageReference Include="NAudio" Version="2.3.0" />
    <PackageReference Include="Nito.AsyncEx.Coordination" Version="5.1.2" />
    <PackageReference Include="System.Drawing.Common" Version="9.0.0" />
    <PackageReference Include="TextCopy" Version="6.2.1" />
  </ItemGroup>

  <!-- beast.ico is embedded (in addition to being the win32 ApplicationIcon) so ConsoleChrome can build
       the animated title-bar icon frames at runtime. -->
  <ItemGroup>
    <EmbeddedResource Include="beast.ico" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Agent\Agent.csproj" />
  </ItemGroup>

</Project>